{
  "name": "portfolio-website",
  "version": "1.0.0",
  "description": "Professional portfolio website for Engr Qasim Khan",
  "scripts": {
    "dev": "five-server . --port=8000 --open=/ --wait=150 --ignore=node_modules --ignore=.git",
    "dev:vercel": "vercel dev --listen 8000",
    "dev:static": "npx http-server -p 8000 -o",
    "start": "npm run dev"
  },
  "keywords": [
    "portfolio",
    "website"
  ],
  "author": "Engr Qasim Khan",
  "license": "MIT",
  "devDependencies": {
    "five-server": "^0.4.5",
    "vercel": "^54.1.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1"
  }
}
